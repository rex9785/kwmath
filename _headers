# Cloudflare Pages _headers
# HTML은 캐시는 OK + 매번 서버에 변경 여부 검증 (must-revalidate)
# 정적 자원(이미지·아이콘·manifest)은 길게 캐시
# sw.js는 항상 최신 (안 그러면 sw 자체가 옛 버전 계속 사용)

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://t1.kakaocdn.net https://developers.kakao.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://www.instagram.com https://www.facebook.com; connect-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self'

# HTML 페이지 — 캐시는 저장하되 매번 변경 여부 체크 (변경 없으면 304, 빠름)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Service Worker — 항상 최신
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# manifest — 항상 최신 (어플 이름/아이콘 변경 즉시 반영)
/manifest.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# 아이콘 — 5분 (변경 빠르게 반영, 그래도 잦은 fetch 방지)
/icons/*
  Cache-Control: public, max-age=300, must-revalidate

# 일반 이미지 — 1일
/*.png
  Cache-Control: public, max-age=86400
/*.jpg
  Cache-Control: public, max-age=86400
